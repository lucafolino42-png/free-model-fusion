// configs/openclaw.json5
// OpenClaw agent configuration — Free Model Fusion
//
// Copy this to ~/.openclaw/openclaw.json (or merge into your existing config)
//
// IMPORTANT: Free Model Fusion uses a custom /chat endpoint, NOT the standard
// OpenAI /v1/chat/completions format. This config works with OpenClaw's
// custom provider setup if your version supports non-OpenAI endpoints.
// See: https://docs.openclaw.ai/gateway/configuration-examples
//
// If OpenClaw requires strict OpenAI compatibility, use the adapter script:
//   node configs/openai-adapter.mjs
// which adds /v1/chat/completions → /chat translation.

{
  // ── General ──────────────────────────────────────────
  "name": "Free Model Fusion",
  "description": "Self-hosted AI router — expert panel + judge + synthesis",

  // ── Models ───────────────────────────────────────────
  "models": {
    "mode": "merge", // Merge with built-in defaults

    "providers": {
      "free-model-fusion": {
        // The base URL of your running Free Model Fusion server
        "baseUrl": "http://localhost:3000",

        // Optional — can be anything since the fusion server doesn't
        // authenticate local requests by default
        "apiKey": "${FUSION_LOCAL_KEY}",

        // If your OpenClaw version supports it, use "custom" or
        // "openai-responses" and change baseUrl to the adapter below.
        // Most OpenClaw versions need strict OpenAI format, so run the
        // adapter first (see README).
        "api": "openai-responses",

        "models": [
          {
            "id": "fusion-balanced",
            "name": "Fusion Balanced",
            "contextWindow": 32000,
            "maxTokens": 4096,
            // Additional custom properties for the fusion pipeline
            "fusionProfile": "balanced",
            "fusionWeb": "auto"
          },
          {
            "id": "fusion-speed",
            "name": "Fusion Speed",
            "contextWindow": 32000,
            "maxTokens": 2048,
            "fusionProfile": "speed"
          },
          {
            "id": "fusion-quality",
            "name": "Fusion Quality",
            "contextWindow": 64000,
            "maxTokens": 8192,
            "fusionProfile": "quality"
          }
        ]
      }
    }
  },

  // ── Channels (optional) ─────────────────────────────
  // Define how OpenClaw exposes the agent. Uncomment to use:
  // "channels": {
  //   "web": {
  //     "enabled": true,
  //     "port": 4000
  //   }
  // }
}
