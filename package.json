{
  "name": "free-model-fusion",
  "version": "1.0.0",
  "description": "Self-hosted, open-source AI router that combines multiple free/cheap AI APIs into one smarter assistant with expert panels, judge/synthesis, memory, web search, Telegram support, and speed-vs-quality routing.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "migrate": "drizzle-kit push",
    "migrate:generate": "drizzle-kit generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "check:models": "tsx scripts/checkModelFreshness.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@libsql/client": "^0.14.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "node-telegram-bot-api": "^0.66.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "drizzle-kit": "^0.30.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
